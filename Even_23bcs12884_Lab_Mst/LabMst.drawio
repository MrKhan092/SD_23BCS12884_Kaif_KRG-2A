        <mxCell id="b91D6cLS04pC_MfKiOOK-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Design a whatsapp system with the proper following requirements&lt;div&gt;user service&lt;/div&gt;&lt;div&gt;chat service&lt;/div&gt;&lt;div&gt;group service&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;optimize chat service for handling the million of request&lt;/div&gt;&lt;div&gt;type of connection used&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;determine how the design will be done for last seen functionality&lt;/div&gt;&lt;div&gt;implement cdc pipeline in the same architecture&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="270" x="-210" y="-720" as="geometry" />
        </mxCell>
        <mxCell id="b91D6cLS04pC_MfKiOOK-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Chat application similar to&amp;nbsp; whatsapp and messenger" vertex="1">
          <mxGeometry height="60" width="350" x="-213.8" y="-440" as="geometry" />
        </mxCell>
        <mxCell id="b91D6cLS04pC_MfKiOOK-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font&gt;Functional Requirements&lt;/font&gt;&lt;div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;&lt;font&gt;User should able to register and login&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;user should be able to send messages(image,text,video) in real time&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;User should be able to create group&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;User should be able to chat in group&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;The last seen of user should be visible&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="380" x="-220" y="50" as="geometry" />
        </mxCell>
        <mxCell id="b91D6cLS04pC_MfKiOOK-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="Non Functional Requirements&lt;div&gt;&lt;ul&gt;&lt;li&gt;Scalabilty - 1.5 Millions daily Active user&amp;nbsp;&amp;nbsp;&lt;/li&gt;&lt;li&gt;CAP&amp;nbsp;&lt;/li&gt;&lt;/ul&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Availability &amp;gt;&amp;gt; Consistency&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Latency - 200 ms(time taken to send messsage through network)&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;Fault Tolerance&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
