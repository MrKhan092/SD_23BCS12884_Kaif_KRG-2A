  <diagram name="Page-1" id="0NC_E4AzEv9o2xY6yrOh">
    <mxGraphModel dx="1910" dy="830" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="kl8vQ2dJPfM_OdWINloe-1" parent="1" style="whiteSpace=wrap;html=1;" value="&lt;font style=&quot;font-size: 21px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Real-Time Collaborative Coding Platform&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="470" x="70" y="110" as="geometry" />
        </mxCell>
        <mxCell id="kl8vQ2dJPfM_OdWINloe-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;ol data-start=&quot;94&quot; data-end=&quot;818&quot;&gt;&lt;p data-pm-slice=&quot;0 0 []&quot; style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Functional Requirements&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Users should be able to authenticate (signup/login) and maintain sessions.&lt;/font&gt;&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Users should be able to create, join, and manage coding sessions.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Multiple users should be able to edit code collaboratively in real time.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Code updates should be synchronized across all participants with consistency.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Users should be able to communicate via real-time chat and video.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Users should be able to execute code and view output/errors.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- The system should track active users and session presence.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Session data (code, metadata) should be stored and retrievable.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- The system should handle events/notifications asynchronously.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;- Access to sessions should be restricted to authorized users.&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="510" width="490" x="30" y="230" as="geometry" />
        </mxCell>
        <mxCell id="kl8vQ2dJPfM_OdWINloe-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Non Functinol Requirement&lt;/b&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;p data-start=&quot;113&quot; data-end=&quot;180&quot;&gt;&lt;strong data-start=&quot;113&quot; data-end=&quot;124&quot;&gt;Scale -&lt;/strong&gt; Support large number of concurrent users and sessions&lt;/p&gt;&lt;p data-start=&quot;182&quot; data-end=&quot;349&quot;&gt;&lt;strong data-start=&quot;182&quot; data-end=&quot;199&quot;&gt;CAP Theorem :&lt;/strong&gt;&lt;br data-start=&quot;199&quot; data-end=&quot;202&quot;&gt;&lt;br&gt;Highly available with respect to joining sessions and real-time updates&lt;br data-start=&quot;273&quot; data-end=&quot;276&quot;&gt;&lt;br&gt;Highly consistent with respect to code synchronization within a session&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="530" x="70" y="750" as="geometry" />
        </mxCell>
        <mxCell id="kl8vQ2dJPfM_OdWINloe-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;h1 data-section-id=&quot;o4yuue&quot; data-start=&quot;356&quot; data-end=&quot;371&quot;&gt;Core Entity&lt;/h1&gt;&lt;ol data-start=&quot;373&quot; data-end=&quot;455&quot;&gt;&lt;li data-section-id=&quot;aualnv&quot; data-start=&quot;373&quot; data-end=&quot;382&quot;&gt;User&lt;/li&gt;&lt;li data-section-id=&quot;ry2xqf&quot; data-start=&quot;383&quot; data-end=&quot;395&quot;&gt;Session&lt;/li&gt;&lt;li data-section-id=&quot;1vgbg6y&quot; data-start=&quot;396&quot; data-end=&quot;414&quot;&gt;Code Document&lt;/li&gt;&lt;li data-section-id=&quot;1uvcmhj&quot; data-start=&quot;415&quot; data-end=&quot;433&quot;&gt;Message/Event&lt;/li&gt;&lt;li data-section-id=&quot;1053u91&quot; data-start=&quot;434&quot; data-end=&quot;455&quot;&gt;Execution Result&amp;nbsp;&lt;/li&gt;&lt;br&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="130" width="160" x="60" y="950" as="geometry" />
        </mxCell>
        <mxCell id="kl8vQ2dJPfM_OdWINloe-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;POST : /v1/session/create&lt;/div&gt;&lt;div&gt;→ Create a new coding session&lt;/div&gt;&lt;div&gt;→ Returns: sessionId&lt;/div&gt;&lt;div&gt;POST : /v1/session/join&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;sessionId&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;→ Join an existing session&lt;/div&gt;&lt;div&gt;GET : /v1/session/{sessionId}&lt;/div&gt;&lt;div&gt;→ Get session details and current code state&lt;/div&gt;&lt;div&gt;POST : /v1/code/update&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;sessionId,&lt;/div&gt;&lt;div&gt;code&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;→ Send code updates (real-time sync via Stream)&lt;/div&gt;&lt;div&gt;POST : /v1/code/execute&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;language,&lt;/div&gt;&lt;div&gt;code&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;→ Execute code and return output&lt;/div&gt;&lt;div&gt;GET : /v1/users/{sessionId}&lt;/div&gt;&lt;div&gt;→ Get list of active users in session&lt;/div&gt;&lt;div&gt;POST : /v1/chat/send&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;sessionId,&lt;/div&gt;&lt;div&gt;message&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;→ Send chat message&lt;/div&gt;" vertex="1">
          <mxGeometry height="460" width="570" x="60" y="1200" as="geometry" />
        </mxCell>
        <mxCell id="kl8vQ2dJPfM_OdWINloe-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;API ENDPOINT&lt;/font&gt;&lt;/b&gt;" vertex="1">
